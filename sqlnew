-- 1. Категории
CREATE TABLE Category (
    cat_id NUMBER PRIMARY KEY,
    cat_name VARCHAR2(50) NOT NULL
);

-- 2. Покупатели
CREATE TABLE Customer (
    cust_id NUMBER PRIMARY KEY,
    name VARCHAR2(100) NOT NULL,
    email VARCHAR2(100) UNIQUE NOT NULL
);

-- 3. Товары
CREATE TABLE Product (
    prod_id NUMBER PRIMARY KEY,
    prod_name VARCHAR2(100) NOT NULL,
    cat_id NUMBER REFERENCES Category(cat_id),
    price NUMBER(8,2) NOT NULL,
    stock NUMBER DEFAULT 0
);

-- 4. Заказы
CREATE TABLE Orders (
    order_id NUMBER PRIMARY KEY,
    cust_id NUMBER REFERENCES Customer(cust_id),
    order_date DATE DEFAULT SYSDATE,
    total NUMBER(8,2) DEFAULT 0
);

-- 5. Корзина (связь заказов с товарами)
CREATE TABLE Cart_Item (
    item_id NUMBER PRIMARY KEY,
    order_id NUMBER REFERENCES Orders(order_id),
    prod_id NUMBER REFERENCES Product(prod_id),
    quantity NUMBER NOT NULL
);




