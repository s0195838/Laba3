-- Что купил каждый покупатель
CREATE VIEW Order_Info AS
SELECT 
    c.name AS покупатель,
    p.prod_name AS товар,
    ci.quantity AS количество,
    (p.price * ci.quantity) AS сумма
FROM Customer c
JOIN Orders o ON c.cust_id = o.cust_id
JOIN Cart_Item ci ON o.order_id = ci.order_id
JOIN Product p ON ci.prod_id = p.prod_id;

-- Автоматический подсчёт суммы заказа
CREATE OR REPLACE TRIGGER calc_total
AFTER INSERT OR UPDATE OR DELETE ON Cart_Item
BEGIN
    FOR rec IN (SELECT DISTINCT order_id FROM Cart_Item) LOOP
        UPDATE Orders o
        SET total = (
            SELECT SUM(p.price * ci.quantity)
            FROM Cart_Item ci
            JOIN Product p ON ci.prod_id = p.prod_id
            WHERE ci.order_id = rec.order_id
        )
        WHERE o.order_id = rec.order_id;
    END LOOP;
END;
/



-- Сумма всех покупок покупателя
CREATE OR REPLACE FUNCTION get_total_spent(p_cust_id NUMBER)
RETURN NUMBER
IS
    v_total NUMBER;
BEGIN
    SELECT NVL(SUM(total), 0) INTO v_total
    FROM Orders
    WHERE cust_id = p_cust_id;
    
    RETURN v_total;
END;
/



-- Добавить товар в заказ
CREATE OR REPLACE PROCEDURE add_to_cart(
    p_order_id NUMBER,
    p_prod_id NUMBER,
    p_quantity NUMBER
)
IS
    v_item_id NUMBER;
    v_stock NUMBER;
BEGIN
    -- Проверяем остаток
    SELECT stock INTO v_stock
    FROM Product
    WHERE prod_id = p_prod_id;
    
    IF v_stock < p_quantity THEN
        DBMS_OUTPUT.PUT_LINE('Ошибка: осталось всего ' || v_stock);
        RETURN;
    END IF;
    
    -- Добавляем в корзину
    SELECT NVL(MAX(item_id), 0) + 1 INTO v_item_id FROM Cart_Item;
    
    INSERT INTO Cart_Item VALUES (v_item_id, p_order_id, p_prod_id, p_quantity);
    
    -- Уменьшаем остаток
    UPDATE Product SET stock = stock - p_quantity WHERE prod_id = p_prod_id;
    
    COMMIT;
    DBMS_OUTPUT.PUT_LINE('Товар добавлен!');
END;
/

-- Посмотреть, кто что купил
SELECT * FROM Order_Info;

-- Узнать, сколько потратил покупатель
SELECT get_total_spent(1) FROM DUAL;

-- Добавить товар в заказ
BEGIN
    add_to_cart(2, 1, 1);  -- в заказ №2 добавить 1 ноутбук
END;
/

