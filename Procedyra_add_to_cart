CREATE OR REPLACE PROCEDURE add_to_cart (
    p_customer_id IN NUMBER,
    p_product_id  IN NUMBER
)
IS
BEGIN
    INSERT INTO CART_ITEM (customer_id, product_id, order_id)
    VALUES (p_customer_id, p_product_id, NULL);
    
    COMMIT;
    DBMS_OUTPUT.PUT_LINE('Товар добавлен в корзину!');
END add_to_cart;
/
